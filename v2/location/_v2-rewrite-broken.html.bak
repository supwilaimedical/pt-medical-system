<!DOCTYPE html>
<html lang="th">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
<meta name="theme-color" content="#0ea5e9">
<title>PT V2 — พิกัดสถานที่</title>
<link rel="manifest" href="../manifest.json">
<link rel="icon" href="../../assets/icon.svg" type="image/svg+xml">
<link rel="stylesheet" href="../shared.css">
<link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css">
<link rel="stylesheet" href="https://unpkg.com/leaflet.markercluster@1.5.3/dist/MarkerCluster.css">
<link rel="stylesheet" href="https://unpkg.com/leaflet.markercluster@1.5.3/dist/MarkerCluster.Default.css">
<style>
  /* Location-specific tweaks */
  .view-section{ display:none; }
  .view-section.active{ display:block; }

  .subnav-tabs{
    background:#fff; border-bottom:1px solid var(--c-border);
    display:flex; overflow-x:auto; flex-shrink:0;
  }
  .subnav-tab{
    padding:10px 14px; font-size:13px; color:#64748b;
    background:none; border:none; white-space:nowrap; cursor:pointer;
    font-family:inherit;
  }
  .subnav-tab.active{
    font-weight:600; color:#0369a1;
    border-bottom:2px solid var(--c-primary);
  }

  .filter-bar{
    padding:10px 12px; background:#fafbfc; border-bottom:1px solid var(--c-border);
    display:flex; gap:6px; flex-wrap:wrap; align-items:center;
  }
  .filter-bar select, .filter-bar input{
    padding:6px 10px; font-size:13px; border:1px solid var(--c-border);
    border-radius:6px; background:#fff; min-width:110px;
  }
  .filter-bar input[type=text]{ flex:1; min-width:160px; }

  .data-table{ width:100%; border-collapse:collapse; background:#fff; }
  .data-table thead th{
    background:#f8fafc; font-size:11px; font-weight:700; color:var(--c-muted);
    text-transform:uppercase; letter-spacing:.04em; text-align:left;
    padding:8px 10px; border-bottom:1px solid var(--c-border);
  }
  .data-table tbody td{
    padding:10px; font-size:13px; border-bottom:1px solid var(--c-border);
    vertical-align:middle;
  }
  .data-table tbody tr:hover{ background:#f8fafc; cursor:pointer; }
  .table-wrap{ background:#fff; border:1px solid var(--c-border); border-radius:var(--radius-lg); overflow:hidden; }
  .table-scroll{ overflow-x:auto; }

  .pager{
    display:flex; justify-content:space-between; align-items:center;
    padding:8px 12px; background:#f8fafc; border-top:1px solid var(--c-border);
    font-size:12px; color:var(--c-muted);
  }
  .pager-btns{ display:flex; gap:4px; align-items:center; }
  .pager-btn{
    background:#fff; border:1px solid var(--c-border); border-radius:6px;
    padding:4px 10px; cursor:pointer; font-family:inherit;
  }
  .pager-btn:disabled{ opacity:.4; cursor:not-allowed; }

  .ct-badge{
    display:inline-block; font-size:10px; padding:2px 8px; border-radius:999px;
    font-weight:600;
  }
  .ct-general{ background:#dbeafe; color:#1e40af; }
  .ct-care{ background:#fef3c7; color:#854d0e; }
  .ct-medical{ background:#fee2e2; color:#991b1b; }
  .ct-hotel{ background:#f3e8ff; color:#6b21a8; }

  .photo-thumb{
    width:60px; height:44px; border-radius:6px; object-fit:cover;
    border:1px solid var(--c-border); flex-shrink:0;
  }

  .form-card{
    max-width:720px; margin:16px auto;
    background:#fff; border:1px solid var(--c-border); border-radius:var(--radius-lg);
    overflow:hidden;
  }
  .form-card-header{
    background:linear-gradient(135deg,#0ea5e9,#0284c7); color:#fff;
    padding:14px 18px; font-weight:700; font-size:15px;
    display:flex; justify-content:space-between; align-items:center;
  }
  .form-card-body{ padding:18px; }

  .photo-upload{
    border:2px dashed var(--c-border); border-radius:var(--radius);
    background:#f8fafc; text-align:center; cursor:pointer;
    padding:30px 16px; min-height:180px;
    display:flex; align-items:center; justify-content:center; flex-direction:column;
    position:relative; overflow:hidden;
  }
  .photo-upload:hover{ border-color:var(--c-primary); background:#f0f9ff; }
  .photo-upload img{ max-height:180px; max-width:100%; object-fit:cover; border-radius:6px; }

  .coords-card{
    background:#f0f9ff; border:1px solid #bae6fd;
    border-radius:var(--radius); padding:12px; margin-bottom:12px;
  }
  .gps-status{ font-size:12px; font-weight:500; margin:6px 0 0; }
  .gps-status.ok{ color:var(--c-success); }
  .gps-status.err{ color:var(--c-danger); }
  .gps-status.info{ color:var(--c-primary); }

  .mono{ font-family:ui-monospace,Consolas,monospace; }

  /* Recent activity sidebar */
  .activity-side{
    width:280px; border-left:1px solid var(--c-border); background:#fff;
    padding:14px; overflow-y:auto; flex-shrink:0;
  }
  @media (max-width: 1023px){ .activity-side{ display:none; } }

  .activity-item{
    display:flex; gap:8px; align-items:center; padding:8px 0;
    border-bottom:1px solid var(--c-border); cursor:pointer;
  }
  .activity-item:hover{ background:#f8fafc; }
  .activity-item img{ width:42px; height:32px; object-fit:cover; border-radius:4px; flex-shrink:0; }

  /* Map */
  .map-area{ flex:1; min-height:400px; position:relative; }
  #loc-map{ width:100%; height:100%; min-height:400px; }
  #loc-minimap{ width:100%; height:60vh; min-height:360px; }

  /* Modal — extended (location uses larger modals than confirm) */
  .modal.lg{ max-width:640px; }
  .modal-section{ padding:14px 20px; }
  .modal-section + .modal-section{ border-top:1px solid var(--c-border); }

  .info-row{
    display:flex; justify-content:space-between; align-items:center; gap:10px;
    background:#f0f9ff; border-radius:6px; padding:10px 12px; margin-top:6px;
  }

  /* Status pills for tokens */
  .status-pill{ font-size:10px; padding:2px 8px; border-radius:999px; font-weight:600; }
  .status-pill.active{ background:#dcfce7; color:#166534; }
  .status-pill.revoked{ background:#fee2e2; color:#991b1b; }
  .status-pill.expired{ background:#e2e8f0; color:#475569; }

  .toast-wrap{
    position:fixed; bottom:20px; left:50%; transform:translateX(-50%);
    background:#0f172a; color:#fff; padding:10px 18px; border-radius:8px;
    font-size:13px; z-index:200; opacity:0; transition:opacity .25s;
    pointer-events:none;
  }
  .toast-wrap.show{ opacity:1; }
  .toast-wrap.success{ background:var(--c-success); }
  .toast-wrap.error{ background:var(--c-danger); }

  .desktop-content-wrap{ display:flex; flex-direction:column; height:100%; min-height:0; }
  .scroll-area{ flex:1; overflow-y:auto; }
  .map-flex{ flex:1; display:flex; min-height:0; }
</style>
</head>
<body>

<!-- ============ MOBILE DRAWER (visible <1024px) ============ -->
<div class="drawer-backdrop" id="drawer-backdrop" onclick="closeDrawer()"></div>
<div class="drawer" id="drawer">
  <div style="padding:18px 14px; border-bottom:1px solid var(--c-border); display:flex; align-items:center; gap:10px;">
    <div class="avatar" id="drawer-avatar">PT</div>
    <div><div style="font-weight:600; font-size:14px;" id="drawer-name">ผู้ใช้</div><div style="font-size:11px; color:var(--c-muted);" id="drawer-role">role</div></div>
  </div>
  <nav style="padding:8px 0;">
    <a class="nav-item" href="../transport/"><span class="nav-icon">🚑</span>นำส่งผู้ป่วย</a>
    <a class="nav-item" href="../firstaid/"><span class="nav-icon">🩹</span>ปฐมพยาบาล</a>
    <a class="nav-item active"><span class="nav-icon">🗺️</span>พิกัดสถานที่</a>
    <a class="nav-item" href="../gps/" id="drawer-gps" style="display:none;"><span class="nav-icon">🛰️</span>GPS Tracking</a>
    <div style="margin:8px 14px; border-top:1px solid var(--c-border); padding-top:8px;">
      <a class="nav-item" href="../"><span class="nav-icon">🏠</span>กลับหน้าหลัก</a>
      <a class="nav-item" href="javascript:doLogout()"><span class="nav-icon">🚪</span>ออกจากระบบ</a>
    </div>
  </nav>
</div>

<!-- ============ APP LAYOUT ============ -->
<div class="layout-3col">

  <!-- Col 1: Nav rail (desktop only) -->
  <aside class="col-nav" id="col-nav">
    <div style="padding:12px 0; justify-content:center; border-bottom:1px solid var(--c-border); display:flex;">
      <div style="width:32px; height:32px; border-radius:8px; background:linear-gradient(135deg,#0ea5e9,#0284c7); color:#fff; display:flex; align-items:center; justify-content:center; font-weight:700; font-size:13px; cursor:pointer;" onclick="toggleNav()">PT</div>
    </div>
    <nav style="flex:1; padding:8px 0;">
      <a class="nav-item" href="../transport/" title="Transport"><span class="nav-icon">🚑</span><span class="nav-label">Transport</span></a>
      <a class="nav-item" href="../firstaid/" title="FirstAid"><span class="nav-icon">🩹</span><span class="nav-label">FirstAid</span></a>
      <a class="nav-item active" title="Location"><span class="nav-icon">🗺️</span><span class="nav-label">Location</span></a>
      <a class="nav-item" href="../gps/" id="rail-gps" title="GPS" style="display:none;"><span class="nav-icon">🛰️</span><span class="nav-label">GPS</span></a>
      <a class="nav-item" href="../monitor/" id="rail-monitor" title="Monitor" style="display:none;"><span class="nav-icon">📡</span><span class="nav-label">Monitor</span></a>
      <a class="nav-item" href="../admin.html" id="rail-admin" title="Admin Settings" style="display:none;"><span class="nav-icon">⚙️</span><span class="nav-label">Admin</span></a>
    </nav>
    <div style="padding:8px;">
      <a class="nav-item" href="../" title="หน้าหลัก"><span class="nav-icon">🏠</span><span class="nav-label">หน้าหลัก</span></a>
    </div>
  </aside>

  <!-- Col 2: Sub-nav (desktop only) -->
  <aside class="col-subnav">
    <div style="padding:12px 14px; border-bottom:1px solid var(--c-border); display:flex; justify-content:space-between; align-items:center;">
      <div>
        <div style="font-weight:700; font-size:14px;">พิกัดสถานที่</div>
        <div style="font-size:11px; color:var(--c-muted);">PT Location</div>
      </div>
      <button class="btn-primary" style="padding:5px 9px; font-size:12px;" onclick="loc_openFormNew()">+ เพิ่ม</button>
    </div>
    <div style="flex:1; overflow-y:auto;">
      <div class="subnav-section">มุมมอง</div>
      <div class="subnav-item" data-tab="dashboard" onclick="loc_switchTab('dashboard')"><span>📊 Dashboard (Map)</span></div>
      <div class="subnav-item" data-tab="customers" onclick="loc_switchTab('customers')"><span>📋 รายการทั้งหมด</span><span class="badge" id="sub-count">0</span></div>
      <div class="subnav-item" data-tab="form" onclick="loc_openFormNew()"><span>➕ เพิ่มสถานที่ใหม่</span></div>

      <div class="subnav-section">ตามประเภท</div>
      <div class="subnav-item" onclick="loc_quickFilterType('สถานพยาบาล')"><span>🏥 สถานพยาบาล</span><span class="badge" id="sub-cnt-medical">0</span></div>
      <div class="subnav-item" onclick="loc_quickFilterType('ลูกค้าทั่วไป')"><span>🏠 ลูกค้าทั่วไป</span><span class="badge" id="sub-cnt-general">0</span></div>
      <div class="subnav-item" onclick="loc_quickFilterType('โรงแรม')"><span>🏨 โรงแรม</span><span class="badge" id="sub-cnt-hotel">0</span></div>
      <div class="subnav-item" onclick="loc_quickFilterType('ศูนย์ดูแล')"><span>🏡 ศูนย์ดูแล</span><span class="badge" id="sub-cnt-care">0</span></div>

      <div class="subnav-section">Share Tokens</div>
      <div class="subnav-item" data-tab="tokens" onclick="loc_switchTab('tokens')"><span>🔗 จัดการลิงก์แชร์</span><span class="badge" id="sub-cnt-tokens">0</span></div>
    </div>
  </aside>

  <!-- Col 3: Content -->
  <section class="col-content">

    <!-- Mobile topbar -->
    <div class="topbar" style="display:none;" id="mobile-topbar">
      <button class="icon-btn" onclick="toggleDrawer()" aria-label="menu">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M3 12h18M3 6h18M3 18h18"/></svg>
      </button>
      <div style="flex:1; min-width:0;">
        <div style="font-weight:600; font-size:14px;">พิกัดสถานที่</div>
        <div style="font-size:11px; color:var(--c-muted);" id="mobile-count">0 รายการ</div>
      </div>
    </div>

    <!-- Sub-nav tabs (works on both mobile & desktop) -->
    <div class="subnav-tabs">
      <button class="subnav-tab" data-tab="dashboard" onclick="loc_switchTab('dashboard')">📊 Dashboard</button>
      <button class="subnav-tab" data-tab="customers" onclick="loc_switchTab('customers')">📋 รายการ</button>
      <button class="subnav-tab" data-tab="form" onclick="loc_openFormNew()">➕ เพิ่ม</button>
      <button class="subnav-tab" data-tab="tokens" onclick="loc_switchTab('tokens')">🔗 Share</button>
    </div>

    <div class="col-body" style="position:relative;">

      <!-- ============ DASHBOARD VIEW ============ -->
      <div id="loc-dashboard-view" class="view-section">
        <div class="filter-bar">
          <select id="loc-dash-filter-type" onchange="loc_handleDashFilterChange()">
            <option value="All">ทุกประเภท</option>
            <option value="ลูกค้าทั่วไป">ลูกค้าทั่วไป</option>
            <option value="ศูนย์ดูแล">ศูนย์ดูแล</option>
            <option value="สถานพยาบาล">สถานพยาบาล</option>
            <option value="โรงแรม">โรงแรม</option>
          </select>
          <select id="loc-dash-filter-province" onchange="loc_onDashProvinceChange()"><option value="All">ทุกจังหวัด</option></select>
          <select id="loc-dash-filter-district" onchange="loc_handleDashFilterChange()"><option value="All">ทุกอำเภอ</option></select>
          <span style="margin-left:auto; font-size:12px; color:var(--c-muted);">รวม <b id="loc-dash-total">0</b> จุด</span>
        </div>
        <div class="map-flex" style="height:calc(100vh - 160px); min-height:400px;">
          <div class="map-area"><div id="loc-map"></div></div>
          <aside class="activity-side">
            <div style="font-size:11px; font-weight:700; color:var(--c-muted); text-transform:uppercase; letter-spacing:.05em; margin-bottom:8px;">เพิ่ม/แก้ไข ล่าสุด</div>
            <div id="loc-dash-recent"></div>
          </aside>
        </div>
      </div>

      <!-- ============ CUSTOMER LIST VIEW ============ -->
      <div id="loc-list-view" class="view-section">
        <div class="filter-bar">
          <input type="text" id="loc-search" placeholder="🔍 ค้นหาชื่อ, เบอร์, รายละเอียด..." oninput="loc_handleFilterChange()">
          <select id="loc-filter-type" onchange="loc_handleFilterChange()">
            <option value="All">ทุกประเภท</option>
            <option value="ลูกค้าทั่วไป">ลูกค้าทั่วไป</option>
            <option value="ศูนย์ดูแล">ศูนย์ดูแล</option>
            <option value="สถานพยาบาล">สถานพยาบาล</option>
            <option value="โรงแรม">โรงแรม</option>
          </select>
          <select id="loc-filter-province" onchange="loc_onProvinceChange()"><option value="All">ทุกจังหวัด</option></select>
          <select id="loc-filter-district" onchange="loc_handleFilterChange()"><option value="All">ทุกอำเภอ</option></select>
          <button id="loc-backfill-btn" class="btn-ghost" style="display:none;" onclick="loc_backfillProvinces()" title="อัปเดตจังหวัด/อำเภอจากพิกัด">
            🌏 อัปเดตพื้นที่ <span class="badge danger" id="loc-backfill-count" style="margin-left:4px;">0</span>
          </button>
        </div>
        <div style="padding:10px;">
          <div class="table-wrap">
            <div class="table-scroll">
              <table class="data-table">
                <thead>
                  <tr>
                    <th>ภาพ / ชื่อ</th>
                    <th>เบอร์</th>
                    <th>พื้นที่</th>
                    <th style="text-align:center;">พิกัด</th>
                    <th style="text-align:right;">จัดการ</th>
                  </tr>
                </thead>
                <tbody id="loc-table-body">
                  <tr><td colspan="5" style="text-align:center; color:var(--c-muted); padding:30px;">กำลังโหลด...</td></tr>
                </tbody>
              </table>
            </div>
            <div class="pager">
              <span id="loc-page-info">แสดง 0 ถึง 0</span>
              <div class="pager-btns">
                <button class="pager-btn" id="loc-btn-prev" onclick="loc_prevPage()">‹</button>
                <span id="loc-page-number">1 / 1</span>
                <button class="pager-btn" id="loc-btn-next" onclick="loc_nextPage()">›</button>
              </div>
            </div>
          </div>
        </div>
      </div>

      <!-- ============ ADD/EDIT FORM VIEW ============ -->
      <div id="loc-form-view" class="view-section">
        <div class="form-card">
          <div class="form-card-header">
            <span id="loc-form-title">➕ เพิ่มพิกัดสถานที่ใหม่</span>
            <button class="icon-btn" style="color:#fff;" onclick="loc_switchTab('customers')" aria-label="close">✕</button>
          </div>
          <div class="form-card-body">
            <form id="loc-customer-form" onsubmit="loc_saveCustomer(event)">
              <input type="hidden" id="loc-form-id">

              <div class="field field-required" style="margin-bottom:14px;">
                <label>รูปถ่ายสถานที่</label>
                <div class="photo-upload" onclick="document.getElementById('loc-form-photo').click()">
                  <img id="loc-form-photo-preview" src="" style="display:none;">
                  <div id="loc-form-photo-placeholder">
                    <div style="font-size:36px; color:#cbd5e1;">🖼️</div>
                    <div style="color:var(--c-muted); font-size:12px; margin-top:6px;">คลิกเพื่ออัปโหลดรูปสถานที่</div>
                  </div>
                  <input type="file" id="loc-form-photo" accept="image/*" style="display:none;" onchange="loc_handlePhotoUpload(this)">
                </div>
                <input type="hidden" id="loc-form-photo-base64">
              </div>

              <div class="field-row-2" style="margin-bottom:10px;">
                <div class="field field-required">
                  <label>ชื่อลูกค้า / เจ้าของบ้าน</label>
                  <input type="text" id="loc-form-name" required>
                </div>
                <div class="field">
                  <label>ประเภทลูกค้า</label>
                  <select id="loc-form-customer-type">
                    <option value="ลูกค้าทั่วไป" selected>ลูกค้าทั่วไป</option>
                    <option value="ศูนย์ดูแล">ศูนย์ดูแล</option>
                    <option value="สถานพยาบาล">สถานพยาบาล</option>
                    <option value="โรงแรม">โรงแรม</option>
                  </select>
                </div>
              </div>

              <div class="field" style="margin-bottom:14px;">
                <label>เบอร์โทรศัพท์ติดต่อ</label>
                <input type="tel" id="loc-form-phone" placeholder="08x-xxx-xxxx">
              </div>

              <div class="coords-card">
                <div style="font-size:13px; font-weight:700; color:#0369a1; margin-bottom:8px;">📍 พิกัดสถานที่ <span style="color:var(--c-danger);">*</span></div>
                <div style="display:flex; gap:6px; flex-wrap:wrap; margin-bottom:8px;">
                  <button type="button" class="btn-primary" style="padding:6px 12px; font-size:12px;" onclick="loc_getGPS()">🎯 ดึงพิกัดปัจจุบัน</button>
                  <input type="text" id="loc-form-maplink" placeholder="วาง Google Maps URL หรือ 13.756,100.501" oninput="loc_extractCoordsFromLink(this.value)" onpaste="setTimeout(()=>loc_extractCoordsFromLink(document.getElementById('loc-form-maplink').value),100)" style="flex:1; min-width:180px; padding:6px 10px; border:1px solid var(--c-border); border-radius:6px; font-size:13px;">
                </div>
                <div class="field-row-2">
                  <div class="field">
                    <label>Latitude</label>
                    <input type="text" id="loc-form-lat" class="mono" required readonly>
                  </div>
                  <div class="field">
                    <label>Longitude</label>
                    <input type="text" id="loc-form-lng" class="mono" required readonly>
                  </div>
                </div>
                <p id="loc-form-gps-status" class="gps-status"></p>
                <div id="loc-form-geo-info" style="display:none; margin-top:8px; align-items:center; gap:8px;">
                  <span class="flag-chip info" id="loc-form-geo-label">📍 <span id="loc-form-geo-text">—</span></span>
                  <button type="button" class="btn-ghost" style="padding:3px 10px; font-size:11px;" onclick="loc_reGeocode()" title="อัปเดตพื้นที่จากพิกัด">↻ อัปเดตพื้นที่</button>
                </div>
              </div>

              <div class="field" style="margin-bottom:16px;">
                <label>รายละเอียด / จุดสังเกต</label>
                <textarea id="loc-form-details" rows="3" placeholder="เช่น บ้านสีฟ้าตรงข้าม 7-11..."></textarea>
              </div>

              <div style="display:flex; gap:8px;">
                <button type="button" class="btn-ghost" style="flex:1;" onclick="loc_switchTab('customers')">ยกเลิก</button>
                <button type="submit" class="btn-primary success" style="flex:1; justify-content:center;" id="loc-form-submit-btn">💾 บันทึก</button>
              </div>
            </form>
          </div>
        </div>
      </div>

      <!-- ============ TOKENS VIEW ============ -->
      <div id="loc-tokens-view" class="view-section">
        <div class="filter-bar">
          <select id="loc-tokens-filter-status" onchange="loc_renderTokensTable()">
            <option value="all">สถานะทั้งหมด</option>
            <option value="active" selected>ใช้งานได้</option>
            <option value="revoked">ถูกระงับ</option>
            <option value="expired">หมดอายุ</option>
          </select>
          <input type="text" id="loc-tokens-search" placeholder="🔍 ค้นหาสถานที่/หมายเหตุ..." oninput="loc_renderTokensTable()">
          <button class="btn-ghost" onclick="loc_bulkDeleteExpired()" style="color:var(--c-danger); border-color:#fecaca;" title="ลบ tokens ที่หมดอายุ+ถูกระงับ">🗑️ ลบข้อมูลเก่า</button>
        </div>
        <div style="padding:10px;">
          <div class="table-wrap">
            <div class="table-scroll">
              <table class="data-table">
                <thead>
                  <tr>
                    <th>สถานที่ / ผู้สร้าง</th>
                    <th>ข้อมูลที่แชร์</th>
                    <th>หมายเหตุ</th>
                    <th style="text-align:center;">หมดอายุ</th>
                    <th style="text-align:center;">สถานะ</th>
                    <th style="text-align:right;">จัดการ</th>
                  </tr>
                </thead>
                <tbody id="loc-tokens-table-body">
                  <tr><td colspan="6" style="text-align:center; color:var(--c-muted); padding:30px;">ไม่มีข้อมูล</td></tr>
                </tbody>
              </table>
            </div>
          </div>
          <div style="margin-top:8px; font-size:12px; color:var(--c-muted);" id="loc-tokens-count"></div>
        </div>
      </div>

    </div>

    <!-- FAB (hidden on form + tokens views) -->
    <button class="fab" id="loc-fab" style="background:linear-gradient(135deg,#22c55e,#15803d); box-shadow:0 6px 16px rgba(34,197,94,.4);" onclick="loc_openFormNew()" title="เพิ่มพิกัดใหม่">+</button>

  </section>
</div>

<!-- ============ CUSTOMER DETAIL MODAL ============ -->
<div class="modal-backdrop" id="modal-customer">
  <div class="modal lg">
    <div class="modal-header" style="display:flex; justify-content:space-between; align-items:center;">
      <span>📍 ข้อมูลสถานที่</span>
      <button class="icon-btn" onclick="closeModal('modal-customer')" aria-label="close">✕</button>
    </div>
    <div class="modal-body" style="padding:0;">
      <div style="height:200px; position:relative; overflow:hidden;">
        <img id="loc-modal-photo" src="" style="width:100%; height:100%; object-fit:cover;">
        <div style="position:absolute; left:0; right:0; bottom:0; padding:10px 14px; background:linear-gradient(transparent,rgba(0,0,0,.65)); color:#fff; font-size:12px; font-weight:500;" id="loc-modal-district">—</div>
      </div>
      <div class="modal-section">
        <div style="font-weight:700; font-size:16px;" id="loc-modal-name">—</div>
        <div style="margin-top:6px;"><span id="loc-modal-type" class="ct-badge">—</span></div>
        <a id="loc-modal-phone" href="#" style="display:none; margin-top:8px; font-size:13px; color:var(--c-success); font-weight:600;">📞 —</a>
      </div>
      <div class="modal-section">
        <div style="font-size:11px; font-weight:700; color:var(--c-muted); text-transform:uppercase;">รายละเอียด / จุดสังเกต</div>
        <div id="loc-modal-details" style="margin-top:6px; background:#f8fafc; border-radius:6px; padding:10px; font-size:13px; line-height:1.5;">—</div>
      </div>
      <div class="modal-section">
        <div style="font-size:11px; font-weight:700; color:var(--c-muted); text-transform:uppercase;">ตำแหน่งพิกัด</div>
        <div class="info-row">
          <span class="mono" style="font-size:12px;" id="loc-modal-coords">—</span>
          <div style="display:flex; gap:6px;">
            <button class="btn-ghost" style="padding:5px 10px; font-size:12px;" onclick="loc_openMiniMap()">🗺️ ดูแผนที่</button>
            <a id="loc-modal-map-link" href="#" target="_blank" class="btn-primary" style="padding:5px 10px; font-size:12px;">🧭 นำทาง</a>
          </div>
        </div>
      </div>
    </div>
    <div class="modal-footer">
      <button class="btn-ghost" onclick="loc_deleteFromModal()" style="color:var(--c-danger); border-color:#fecaca;">🗑️ ลบ</button>
      <button class="btn-ghost" onclick="loc_createShareLink()">🔗 แชร์ลิงก์</button>
      <button class="btn-primary" onclick="loc_editFromModal()">✏️ แก้ไข</button>
    </div>
  </div>
</div>

<!-- ============ MINI MAP MODAL ============ -->
<div class="modal-backdrop" id="modal-minimap">
  <div class="modal lg" style="max-width:720px;">
    <div class="modal-header" style="display:flex; justify-content:space-between; align-items:center;">
      <span>🗺️ <span id="loc-minimap-name">แผนที่</span></span>
      <button class="icon-btn" onclick="closeModal('modal-minimap')" aria-label="close">✕</button>
    </div>
    <div class="modal-body" style="padding:0;">
      <div id="loc-minimap"></div>
      <div style="padding:10px 14px; border-top:1px solid var(--c-border); display:flex; justify-content:space-between; align-items:center; flex-wrap:wrap; gap:8px;">
        <span class="mono" style="font-size:12px; color:var(--c-muted);" id="loc-minimap-coords">—</span>
        <a id="loc-minimap-nav-link" href="#" target="_blank" class="btn-primary" style="padding:6px 12px; font-size:12px;">🧭 เปิดใน Google Maps</a>
      </div>
    </div>
  </div>
</div>

<!-- ============ SHARE LINK MODAL ============ -->
<div class="modal-backdrop" id="modal-share">
  <div class="modal">
    <div class="modal-header" style="display:flex; justify-content:space-between; align-items:center;">
      <span>🔗 สร้างลิงก์แชร์</span>
      <button class="icon-btn" onclick="closeModal('modal-share')" aria-label="close">✕</button>
    </div>
    <div class="modal-body">
      <div style="font-size:12px; color:var(--c-muted); margin-bottom:6px;">สำหรับส่งต่อข้อมูลสถานที่:</div>
      <div id="locShareCustomerInfo" style="background:#f0f9ff; border-radius:6px; padding:10px; margin-bottom:14px; font-size:13px;"></div>

      <div class="field" style="margin-bottom:12px;">
        <label>อายุลิงก์</label>
        <select id="locShareExpiry">
          <option value="1">1 ชั่วโมง</option>
          <option value="24" selected>24 ชั่วโมง (1 วัน)</option>
          <option value="168">7 วัน</option>
          <option value="720">30 วัน</option>
        </select>
      </div>

      <div class="field" style="margin-bottom:12px;">
        <label>หมายเหตุ (ไม่บังคับ)</label>
        <input type="text" id="locShareNote" placeholder="เช่น ส่งให้คุณ A ไปรับของแทน" maxlength="100">
      </div>

      <div class="field" style="margin-bottom:8px;">
        <label>ข้อมูลที่จะเปิดให้ผู้รับลิงก์เห็น</label>
        <div id="locShareFieldsWrap" style="background:#f0fdf4; border-radius:6px; padding:8px;"></div>
      </div>

      <div id="locShareValidation" style="display:none; color:var(--c-danger); font-size:12px; margin-top:6px;"></div>
    </div>
    <div class="modal-footer">
      <button class="btn-ghost" onclick="closeModal('modal-share')">ยกเลิก</button>
      <button class="btn-primary success" id="locShareSubmitBtn" onclick="loc_submitShareLink()">🔗 สร้างลิงก์</button>
    </div>
  </div>
</div>

<!-- ============ SHARE RESULT MODAL ============ -->
<div class="modal-backdrop" id="modal-share-result">
  <div class="modal">
    <div class="modal-header" style="background:#f0fdf4; color:var(--c-success); display:flex; justify-content:space-between; align-items:center;">
      <span>✓ สร้างลิงก์สำเร็จ</span>
      <button class="icon-btn" onclick="closeModal('modal-share-result')" aria-label="close">✕</button>
    </div>
    <div class="modal-body">
      <div style="font-size:12px; color:var(--c-muted); margin-bottom:6px;">ลิงก์สำหรับส่งต่อ (คลิกเพื่อเลือกและคัดลอก):</div>
      <input type="text" id="locShareResultUrl" readonly class="mono" style="width:100%; padding:8px 10px; border:1px solid var(--c-border); border-radius:6px; background:#f0fdf4; font-size:12px; margin-bottom:8px;" onclick="this.select()">
      <button class="btn-primary success" style="width:100%; justify-content:center;" onclick="loc_copyResultLink()">📋 คัดลอกลิงก์</button>
      <div style="font-size:12px; color:var(--c-muted); margin-top:8px;" id="locShareResultExpire"></div>
      <div id="locShareResultWarning"></div>
    </div>
  </div>
</div>

<!-- ============ CONFIRM MODAL (generic) ============ -->
<div class="modal-backdrop" id="modal-confirm">
  <div class="modal" style="max-width:380px;">
    <div class="modal-header" id="confirm-title">ยืนยัน</div>
    <div class="modal-body" id="confirm-body">—</div>
    <div class="modal-footer">
      <button class="btn-ghost" onclick="closeModal('modal-confirm'); _confirmCb && _confirmCb(false);">ยกเลิก</button>
      <button class="btn-primary" id="confirm-ok-btn" onclick="closeModal('modal-confirm'); _confirmCb && _confirmCb(true);">ตกลง</button>
    </div>
  </div>
</div>

<!-- Toast -->
<div class="toast-wrap" id="toast"></div>

<!-- ============ SCRIPTS ============ -->
<script src="../../shared/config.js"></script>
<script src="https://cdn.jsdelivr.net/npm/@supabase/supabase-js@2/dist/umd/supabase.min.js"></script>
<script src="../../shared/auth.js"></script>
<script src="../../shared/realtime.js"></script>
<script src="../../shared/cloudinary.js"></script>
<script src="../../shared/map-config.js"></script>
<script src="../shared.js"></script>
<script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js"></script>
<script src="https://unpkg.com/leaflet.markercluster@1.5.3/dist/leaflet.markercluster.js"></script>

<script>
// ============================================================
// PT V2 — Location Module
// Preserves V1 IDs/field names for Supabase compat
// ============================================================

// --- HELPERS ---
function escapeHtml(s){
  if(s == null) return '';
  return String(s).replace(/[&<>"']/g, function(c){
    return {'&':'&amp;','<':'&lt;','>':'&gt;','"':'&quot;',"'":'&#39;'}[c];
  });
}

function toast(msg, type){
  var el = document.getElementById('toast');
  el.textContent = msg;
  el.className = 'toast-wrap show ' + (type || '');
  clearTimeout(window._toastT);
  window._toastT = setTimeout(function(){ el.classList.remove('show'); }, 1800);
}

var _confirmCb = null;
function confirmDialog(title, body, okText, danger){
  return new Promise(function(resolve){
    document.getElementById('confirm-title').textContent = title || 'ยืนยัน';
    document.getElementById('confirm-body').innerHTML = body || '';
    var btn = document.getElementById('confirm-ok-btn');
    btn.textContent = okText || 'ตกลง';
    btn.className = 'btn-primary' + (danger ? '' : '');
    if(danger){ btn.style.background = 'var(--c-danger)'; } else { btn.style.background = ''; }
    _confirmCb = function(ok){ _confirmCb = null; resolve(ok); };
    openModal('modal-confirm');
  });
}

// --- GLOBAL STATE (V1 names) ---
var loc_customers = [];
var loc_filteredCustomers = [];
var loc_dashFiltered = null;
var loc_sharedTokensData = [];
var loc_currentPage = 1;
var LOC_ITEMS_PER_PAGE = 20;
var loc_selectedCustomerId = null;
var loc_leafletMap = null;
var loc_markersCluster = null;
var _locShareTargetCustomerId = null;
// _supabase = global const from shared/auth.js (do NOT redeclare with var/let)

var LOC_SHARE_FIELDS = [
  { key: 'name',    label: 'ชื่อลูกค้า/เจ้าของบ้าน',     default: true  },
  { key: 'phone',   label: 'เบอร์โทรศัพท์ติดต่อ',        default: false },
  { key: 'coords',  label: 'พิกัดและปุ่มเปิดแผนที่',    default: true  },
  { key: 'details', label: 'รายละเอียดจุดสังเกต',        default: false },
  { key: 'photo',   label: 'รูปถ่ายสถานที่',              default: true  }
];

var CT_CLASS = {
  'ลูกค้าทั่วไป':'ct-general',
  'ศูนย์ดูแล':'ct-care',
  'สถานพยาบาล':'ct-medical',
  'โรงแรม':'ct-hotel'
};
var CT_PIN = {
  'ลูกค้าทั่วไป':'#0ea5e9',
  'ศูนย์ดูแล':'#f59e0b',
  'สถานพยาบาล':'#dc2626',
  'โรงแรม':'#a855f7'
};

// --- INIT ---
window.addEventListener('load', async function(){
  try {
    // V1 pattern: _supabase = global const from shared/auth.js
    // V1 pattern: isLoggedIn() + getUserMeta() (localStorage-based, 8h timeout)
    if(typeof isLoggedIn !== 'function' || !isLoggedIn()){
      window.location.href = '../'; return;
    }
    var u = (typeof getUserMeta === 'function') ? getUserMeta() : null;
    if(!u){ window.location.href = '../'; return; }
    document.getElementById('drawer-name').textContent = u.full_name || u.username || 'ผู้ใช้';
    document.getElementById('drawer-role').textContent = (u.role || 'user') + ' · ' + (u.org || '');
    document.getElementById('drawer-avatar').textContent = (u.full_name || u.username || 'PT').substring(0,2).toUpperCase();
    window._loc_isAdmin = (u.role||'').toLowerCase().indexOf('admin') !== -1;

    // Show admin-only nav items (rail + drawer)
    if(window._loc_isAdmin){
      ['rail-gps','rail-monitor','rail-admin','drawer-gps'].forEach(function(id){
        var el = document.getElementById(id); if(el) el.style.display = '';
      });
    }

    // Show mobile topbar on small screens
    if(window.matchMedia('(max-width: 1023px)').matches){
      document.getElementById('mobile-topbar').style.display = '';
    }

    await loc_fetchData();
    loc_switchTab('dashboard');

    // Realtime: auto-refresh list when loc_customers changes (port from V1)
    try {
      if(window.RT && typeof RT.subscribe === 'function'){
        if(typeof RT.initStatusDot === 'function') RT.initStatusDot();
        RT.subscribe('pt-location-list', 'loc_customers', function(){ loc_fetchData().then(function(){
          // Refresh whichever view is active
          var active = document.querySelector('.view-section.active');
          if(!active) return;
          if(active.id === 'loc-dashboard-view') loc_renderDashboard();
          else if(active.id === 'loc-list-view') loc_handleFilterChange();
          else if(active.id === 'loc-tokens-view') loc_renderTokensTable();
        }); });
        RT.subscribe('pt-location-tokens', 'loc_shared_tokens', function(){ loc_fetchData(); });
      }
    } catch(rtErr){ console.warn('Realtime subscribe failed:', rtErr); }
  } catch(e){
    console.error('init failed', e);
    toast('โหลดล้มเหลว: ' + (e.message || e), 'error');
  }
});

function doLogout(){
  try { localStorage.removeItem('pt_user_meta'); } catch(_){}
  window.location.href = '../';
}

// --- DATA FETCH ---
async function loc_fetchData(){
  try {
    var cRes = await _supabase.from('loc_customers').select('*').order('date_added', { ascending: false });
    if(cRes.error) throw cRes.error;
    loc_customers = (cRes.data || []).map(function(c){
      return {
        id: c.id, name: c.name, phone: c.phone, lat: c.lat, lng: c.lng,
        district: c.district, province: c.province, details: c.details,
        photo: c.photo_url, customer_type: c.customer_type, date_added: c.date_added
      };
    });
    var tRes = await _supabase.from('loc_shared_tokens').select('*').order('created_at', { ascending: false });
    if(!tRes.error) loc_sharedTokensData = tRes.data || [];

    loc_populateFilters();
    loc_updateBackfillBadge();
    loc_updateCounts();
  } catch(err){
    console.error('[loc_fetchData] failed:', err);
    toast('โหลดข้อมูลล้มเหลว: ' + (err.message || err), 'error');
  }
}

function loc_updateCounts(){
  var by = {'สถานพยาบาล':0,'ลูกค้าทั่วไป':0,'โรงแรม':0,'ศูนย์ดูแล':0};
  loc_customers.forEach(function(c){
    var t = c.customer_type || 'ลูกค้าทั่วไป';
    if(by[t] != null) by[t]++;
  });
  document.getElementById('sub-count').textContent = loc_customers.length;
  document.getElementById('sub-cnt-medical').textContent = by['สถานพยาบาล'];
  document.getElementById('sub-cnt-general').textContent = by['ลูกค้าทั่วไป'];
  document.getElementById('sub-cnt-hotel').textContent = by['โรงแรม'];
  document.getElementById('sub-cnt-care').textContent = by['ศูนย์ดูแล'];
  var actives = (loc_sharedTokensData || []).filter(function(t){
    var e = t.expiry_date ? new Date(t.expiry_date).getTime() : Infinity;
    return t.status !== 'Revoked' && e >= Date.now();
  }).length;
  document.getElementById('sub-cnt-tokens').textContent = actives;
  document.getElementById('mobile-count').textContent = loc_customers.length + ' รายการ';
}

// --- TAB SWITCH ---
function loc_switchTab(tabId){
  document.querySelectorAll('.view-section').forEach(function(v){ v.classList.remove('active'); });
  document.querySelectorAll('.subnav-tab, .subnav-item').forEach(function(b){ b.classList.remove('active'); });
  document.querySelectorAll('[data-tab="'+tabId+'"]').forEach(function(b){ b.classList.add('active'); });

  if(tabId === 'dashboard'){
    document.getElementById('loc-dashboard-view').classList.add('active');
    loc_renderDashboard();
  } else if(tabId === 'customers'){
    document.getElementById('loc-list-view').classList.add('active');
    loc_handleFilterChange();
  } else if(tabId === 'form'){
    document.getElementById('loc-form-view').classList.add('active');
  } else if(tabId === 'tokens'){
    document.getElementById('loc-tokens-view').classList.add('active');
    loc_renderTokensTable();
  }
  var fab = document.getElementById('loc-fab');
  fab.style.display = (tabId === 'form' || tabId === 'tokens') ? 'none' : 'flex';
}

function loc_quickFilterType(type){
  loc_switchTab('customers');
  var sel = document.getElementById('loc-filter-type');
  sel.value = type;
  loc_handleFilterChange();
}

// --- FILTERS ---
function loc_populateFilters(){
  var provs = [];
  loc_customers.forEach(function(c){
    if(c.province && provs.indexOf(c.province) === -1 && c.province !== 'ไม่ระบุจังหวัด') provs.push(c.province);
  });
  provs.sort();
  var html = '<option value="All">ทุกจังหวัด</option>' + provs.map(function(p){ return '<option value="'+escapeHtml(p)+'">จ.'+escapeHtml(p)+'</option>'; }).join('');
  ['loc-filter-province','loc-dash-filter-province'].forEach(function(id){
    var el = document.getElementById(id); if(el) el.innerHTML = html;
  });
  loc_onProvinceChange();
  loc_onDashProvinceChange();
}

function loc_buildDistrictOptions(selProv){
  var dists = [];
  loc_customers.forEach(function(c){
    if((selProv === 'All' || c.province === selProv) && c.district && dists.indexOf(c.district) === -1 && c.district !== 'ไม่ระบุอำเภอ') dists.push(c.district);
  });
  dists.sort();
  return '<option value="All">ทุกอำเภอ</option>' + dists.map(function(d){ return '<option value="'+escapeHtml(d)+'">อ.'+escapeHtml(d)+'</option>'; }).join('');
}
function loc_onProvinceChange(){
  var p = (document.getElementById('loc-filter-province') || {}).value || 'All';
  var el = document.getElementById('loc-filter-district'); if(el) el.innerHTML = loc_buildDistrictOptions(p);
  loc_handleFilterChange();
}
function loc_onDashProvinceChange(){
  var p = (document.getElementById('loc-dash-filter-province') || {}).value || 'All';
  var el = document.getElementById('loc-dash-filter-district'); if(el) el.innerHTML = loc_buildDistrictOptions(p);
  loc_handleDashFilterChange();
}

function loc_handleDashFilterChange(){
  var prov = (document.getElementById('loc-dash-filter-province') || {}).value || 'All';
  var dist = (document.getElementById('loc-dash-filter-district') || {}).value || 'All';
  var type = (document.getElementById('loc-dash-filter-type') || {}).value || 'All';
  loc_dashFiltered = loc_customers.filter(function(c){
    return (prov === 'All' || c.province === prov)
        && (dist === 'All' || c.district === dist)
        && (type === 'All' || (c.customer_type || 'ลูกค้าทั่วไป') === type);
  });
  loc_renderDashboard();
}

function loc_handleFilterChange(){
  var raw = (document.getElementById('loc-search') || {}).value || '';
  var search = raw.toLowerCase();
  var numSearch = raw.replace(/\D/g, '');
  var prov = (document.getElementById('loc-filter-province') || {}).value || 'All';
  var dist = (document.getElementById('loc-filter-district') || {}).value || 'All';
  var type = (document.getElementById('loc-filter-type') || {}).value || 'All';
  loc_filteredCustomers = loc_customers.filter(function(c){
    var mp = prov === 'All' || c.province === prov;
    var md = dist === 'All' || c.district === dist;
    var mt = type === 'All' || (c.customer_type || 'ลูกค้าทั่วไป') === type;
    var ms = !search || (c.name || '').toLowerCase().indexOf(search) >= 0
          || (numSearch && String(c.phone || '').replace(/\D/g, '').indexOf(numSearch) >= 0)
          || (c.details || '').toLowerCase().indexOf(search) >= 0;
    return mp && md && mt && ms;
  });
  loc_currentPage = 1;
  loc_renderTable();
}

// --- TABLE ---
function loc_renderTable(){
  var tbody = document.getElementById('loc-table-body');
  if(!tbody) return;
  var total = Math.ceil(loc_filteredCustomers.length / LOC_ITEMS_PER_PAGE) || 1;
  if(loc_filteredCustomers.length === 0){
    tbody.innerHTML = '<tr><td colspan="5" style="text-align:center; color:var(--c-muted); padding:30px;">ไม่พบข้อมูล</td></tr>';
    loc_updatePagination(0, 0, total); return;
  }
  var start = (loc_currentPage - 1) * LOC_ITEMS_PER_PAGE;
  var end = Math.min(start + LOC_ITEMS_PER_PAGE, loc_filteredCustomers.length);
  var html = '';
  loc_filteredCustomers.slice(start, end).forEach(function(c, idx){
    var photo = c.photo || 'https://via.placeholder.com/150?text=No+Image';
    var ct = c.customer_type || 'ลูกค้าทั่วไป';
    var badge = '<span class="ct-badge '+(CT_CLASS[ct]||'ct-general')+'">'+escapeHtml(ct)+'</span>';
    var kebabId = 'kebab-row-' + (start+idx);
    html += '<tr onclick="loc_openModal(\''+escapeHtml(c.id)+'\')">'
      + '<td><div style="display:flex; align-items:center; gap:10px;">'
        + '<img src="'+escapeHtml(photo)+'" onerror="this.src=\'https://via.placeholder.com/150\'" class="photo-thumb">'
        + '<div><div style="font-weight:600;">'+escapeHtml(c.name||'')+'</div><div style="margin-top:2px;">'+badge+'</div></div>'
      + '</div></td>'
      + '<td style="color:var(--c-muted);">'+escapeHtml(c.phone || '-')+'</td>'
      + '<td>อ.'+escapeHtml(c.district||'ไม่ระบุ')+'<div style="font-size:11px; color:var(--c-muted);">จ.'+escapeHtml(c.province||'ไม่ระบุ')+'</div></td>'
      + '<td style="text-align:center;"><a href="https://www.google.com/maps/search/?api=1&query='+c.lat+','+c.lng+'" target="_blank" onclick="event.stopPropagation();" class="btn-ghost" style="padding:4px 10px; font-size:12px;">🗺️ Maps</a></td>'
      + '<td style="text-align:right;" onclick="event.stopPropagation();">'
        + '<div class="kebab-wrap">'
          + '<button class="kebab-btn" onclick="kebab(event,\''+kebabId+'\')"><svg viewBox="0 0 24 24" fill="currentColor" width="16" height="16"><circle cx="12" cy="5" r="1.8"/><circle cx="12" cy="12" r="1.8"/><circle cx="12" cy="19" r="1.8"/></svg></button>'
          + '<div class="kebab-menu" id="'+kebabId+'">'
            + '<button class="kebab-item" onclick="loc_openModal(\''+escapeHtml(c.id)+'\')">👁️ ดูรายละเอียด</button>'
            + '<button class="kebab-item" onclick="window.open(\'https://www.google.com/maps/search/?api=1&query='+c.lat+','+c.lng+'\',\'_blank\')">🗺️ เปิดในแผนที่</button>'
            + '<button class="kebab-item" onclick="loc_openFormEdit(\''+escapeHtml(c.id)+'\')">✏️ แก้ไข</button>'
            + '<button class="kebab-item" onclick="loc_shareCustomerFromRow(\''+escapeHtml(c.id)+'\')">🔗 แชร์ลิงก์</button>'
            + '<div class="kebab-divider"></div>'
            + '<button class="kebab-item danger" onclick="loc_deleteCustomer(\''+escapeHtml(c.id)+'\')">🗑️ ลบ</button>'
          + '</div>'
        + '</div>'
      + '</td>'
    + '</tr>';
  });
  tbody.innerHTML = html;
  loc_updatePagination(start + 1, end, total);
}

function loc_updatePagination(s, e, t){
  var info = document.getElementById('loc-page-info'); if(info) info.textContent = 'แสดง ' + s + ' ถึง ' + e + ' จาก ' + loc_filteredCustomers.length;
  var pn = document.getElementById('loc-page-number'); if(pn) pn.textContent = loc_currentPage + ' / ' + t;
  var bp = document.getElementById('loc-btn-prev'); if(bp) bp.disabled = loc_currentPage <= 1;
  var bn = document.getElementById('loc-btn-next'); if(bn) bn.disabled = loc_currentPage >= t;
}
function loc_prevPage(){ if(loc_currentPage > 1){ loc_currentPage--; loc_renderTable(); } }
function loc_nextPage(){ var t = Math.ceil(loc_filteredCustomers.length / LOC_ITEMS_PER_PAGE); if(loc_currentPage < t){ loc_currentPage++; loc_renderTable(); } }

// --- DELETE customer ---
async function loc_deleteCustomer(id){
  var ok = await confirmDialog('ยืนยันการลบ?', 'ข้อมูลสถานที่นี้จะถูกลบถาวร', 'ลบข้อมูล', true);
  if(!ok) return;
  var delTarget = (loc_customers.find(function(x){ return x.id === id; }) || {});
  var res = await _supabase.from('loc_customers').delete().eq('id', id);
  if(res.error){ toast('ผิดพลาด: ' + res.error.message, 'error'); return; }
  try {
    await _supabase.from('activity_log').insert({
      username: (typeof getUserName === 'function' ? getUserName() : 'Unknown'),
      role: (typeof getUserRole === 'function' ? getUserRole() : 'User'),
      action: 'LOC_DELETE',
      target: delTarget.name || id,
      details: 'ลบสถานที่ id=' + id
    });
  } catch(_){}
  toast('ลบเรียบร้อย', 'success');
  await loc_fetchData();
  loc_switchTab('customers');
}
function loc_deleteFromModal(){
  closeModal('modal-customer');
  if(loc_selectedCustomerId) loc_deleteCustomer(loc_selectedCustomerId);
}

// --- FORM ---
function loc_openFormNew(){
  loc_resetForm();
  document.getElementById('loc-form-title').innerHTML = '➕ เพิ่มพิกัดสถานที่ใหม่';
  document.getElementById('loc-form-submit-btn').innerHTML = '💾 บันทึกข้อมูลใหม่';
  loc_switchTab('form');
}

function loc_openFormEdit(id){
  loc_resetForm();
  var c = loc_customers.find(function(x){ return x.id === id; });
  if(!c) return;
  var s = function(id2, val){ var el = document.getElementById(id2); if(el) el.value = val == null ? '' : val; };
  s('loc-form-id', c.id); s('loc-form-name', c.name); s('loc-form-customer-type', c.customer_type || 'ลูกค้าทั่วไป');
  s('loc-form-phone', c.phone); s('loc-form-lat', c.lat); s('loc-form-lng', c.lng); s('loc-form-details', c.details);
  if(c.photo){
    s('loc-form-photo-base64', c.photo);
    var pvw = document.getElementById('loc-form-photo-preview');
    if(pvw){ pvw.src = c.photo; pvw.onerror = function(){ this.src = 'https://via.placeholder.com/400x300'; }; pvw.style.display = ''; }
    var ph = document.getElementById('loc-form-photo-placeholder'); if(ph) ph.style.display = 'none';
  }
  document.getElementById('loc-form-title').innerHTML = '✏️ แก้ไขพิกัดสถานที่';
  document.getElementById('loc-form-submit-btn').innerHTML = '💾 อัปเดตข้อมูล';
  loc_switchTab('form');
  if(c.lat && c.lng){
    var bad = ['ไม่ระบุจังหวัด','ไม่ระบุอำเภอ','ไม่ระบุ','',null,undefined];
    var hasMissing = bad.indexOf(c.district) >= 0 || bad.indexOf(c.province) >= 0;
    loc_showGeoInfo(c.district, c.province);
    if(hasMissing) loc_reGeocode();
  }
}

function loc_showGeoInfo(district, province){
  var wrap = document.getElementById('loc-form-geo-info');
  var txt = document.getElementById('loc-form-geo-text');
  if(!wrap || !txt) return;
  txt.textContent = 'อ.' + (district || 'ไม่ระบุ') + ' จ.' + (province || 'ไม่ระบุ');
  wrap.style.display = 'flex';
}

async function loc_reGeocode(){
  var lat = parseFloat(document.getElementById('loc-form-lat').value);
  var lng = parseFloat(document.getElementById('loc-form-lng').value);
  if(isNaN(lat) || isNaN(lng)) return;
  var txt = document.getElementById('loc-form-geo-text');
  var wrap = document.getElementById('loc-form-geo-info');
  if(txt) txt.textContent = '⏳ กำลังหาพื้นที่...';
  if(wrap) wrap.style.display = 'flex';
  var geo = await loc_reverseGeocode(lat, lng);
  if(txt) txt.textContent = 'อ.' + geo.district + ' จ.' + geo.province;
  var geoCache = document.getElementById('loc-form-geo-cache');
  if(!geoCache){
    geoCache = document.createElement('input');
    geoCache.type = 'hidden'; geoCache.id = 'loc-form-geo-cache';
    document.getElementById('loc-customer-form').appendChild(geoCache);
  }
  geoCache.value = JSON.stringify(geo);
}

function loc_resetForm(){
  var f = document.getElementById('loc-customer-form'); if(f) f.reset();
  var b = document.getElementById('loc-form-photo-base64'); if(b) b.value = '';
  var p = document.getElementById('loc-form-photo-preview'); if(p){ p.src = ''; p.style.display = 'none'; }
  var ph = document.getElementById('loc-form-photo-placeholder'); if(ph) ph.style.display = '';
  var st = document.getElementById('loc-form-gps-status'); if(st){ st.textContent = ''; st.className = 'gps-status'; }
  var gi = document.getElementById('loc-form-geo-info'); if(gi) gi.style.display = 'none';
  var gc = document.getElementById('loc-form-geo-cache'); if(gc) gc.value = '';
}

// --- PHOTO ---
function loc_handlePhotoUpload(input){
  if(!input.files || !input.files[0]) return;
  var reader = new FileReader();
  reader.onload = function(e){
    var img = new Image();
    img.onload = function(){
      var MAX = 1024, w = img.width, h = img.height;
      if(w > h){ if(w > MAX){ h *= MAX / w; w = MAX; } }
      else { if(h > MAX){ w *= MAX / h; h = MAX; } }
      var canvas = document.createElement('canvas'); canvas.width = w; canvas.height = h;
      canvas.getContext('2d').drawImage(img, 0, 0, w, h);
      var compressed = canvas.toDataURL('image/jpeg', 0.7);
      document.getElementById('loc-form-photo-base64').value = compressed;
      var pvw = document.getElementById('loc-form-photo-preview'); if(pvw){ pvw.src = compressed; pvw.style.display = ''; }
      document.getElementById('loc-form-photo-placeholder').style.display = 'none';
    };
    img.src = e.target.result;
  };
  reader.readAsDataURL(input.files[0]);
}

// --- GPS / COORDS PARSING ---
function loc_getGPS(){
  var st = document.getElementById('loc-form-gps-status');
  st.textContent = '⏳ กำลังร้องขอพิกัด GPS...'; st.className = 'gps-status info';
  if(!navigator.geolocation){ st.textContent = '❌ อุปกรณ์ไม่รองรับ GPS'; st.className = 'gps-status err'; return; }
  navigator.geolocation.getCurrentPosition(
    function(pos){
      document.getElementById('loc-form-lat').value = pos.coords.latitude.toFixed(6);
      document.getElementById('loc-form-lng').value = pos.coords.longitude.toFixed(6);
      st.textContent = '✓ อัปเดตพิกัดเรียบร้อย'; st.className = 'gps-status ok';
      loc_reGeocode();
    },
    function(err){ st.textContent = '❌ ' + err.message; st.className = 'gps-status err'; },
    { enableHighAccuracy: true, timeout: 15000, maximumAge: 0 }
  );
}

function loc_extractCoordsFromLink(url){
  if(!url || url.length < 10) return;
  var st = document.getElementById('loc-form-gps-status');
  if(/^https?:\/\/(maps\.app\.goo\.gl|goo\.gl\/maps|bit\.ly|shorturl)/i.test(url)){
    loc_expandShortUrl(url); return;
  }
  var coords = loc_parseGoogleMapsUrl(url);
  if(coords){
    document.getElementById('loc-form-lat').value = coords.lat;
    document.getElementById('loc-form-lng').value = coords.lng;
    st.textContent = '✓ ดึงพิกัดจากลิงก์เรียบร้อย'; st.className = 'gps-status ok';
    loc_reGeocode();
  } else {
    st.textContent = '⚠ ไม่พบพิกัดในลิงก์ — ลองใช้ลิงก์แบบเต็ม'; st.className = 'gps-status err';
  }
}

function loc_parseGoogleMapsUrl(url){
  var patterns = [
    /!3d([-]?[0-9]+\.[0-9]+)!4d([-]?[0-9]+\.[0-9]+)/,
    /@([-]?[0-9]+\.[0-9]+),([-]?[0-9]+\.[0-9]+)/,
    /[?&]q=([-]?[0-9]+\.[0-9]+),([-]?[0-9]+\.[0-9]+)/,
    /[?&]ll=([-]?[0-9]+\.[0-9]+),([-]?[0-9]+\.[0-9]+)/,
    /[?&]center=([-]?[0-9]+\.[0-9]+),([-]?[0-9]+\.[0-9]+)/,
    /[?&]sll=([-]?[0-9]+\.[0-9]+),([-]?[0-9]+\.[0-9]+)/,
    /[?&][ds]addr=([-]?[0-9]+\.[0-9]+),([-]?[0-9]+\.[0-9]+)/,
    /\/dir\/([-]?[0-9]+\.[0-9]+),([-]?[0-9]+\.[0-9]+)/,
    /\/search\/([-]?[0-9]+\.[0-9]+)[,+%20]+([-]?[0-9]+\.[0-9]+)/,
    /([-]?[0-9]{1,2}\.[0-9]{4,8})[,%20+]+([-]?[0-9]{1,3}\.[0-9]{4,8})/
  ];
  for(var i=0;i<patterns.length;i++){
    var m = url.match(patterns[i]);
    if(m){
      var lat = parseFloat(m[1]), lng = parseFloat(m[2]);
      if(lat >= -90 && lat <= 90 && lng >= -180 && lng <= 180){
        return { lat: lat.toFixed(6), lng: lng.toFixed(6) };
      }
    }
  }
  return null;
}

async function loc_expandShortUrl(shortUrl){
  var st = document.getElementById('loc-form-gps-status');
  st.textContent = '⏳ กำลังขยายลิงก์ย่อ...'; st.className = 'gps-status info';
  function setCoords(coords){
    document.getElementById('loc-form-lat').value = coords.lat;
    document.getElementById('loc-form-lng').value = coords.lng;
    st.textContent = '✓ ดึงพิกัดจากลิงก์ย่อเรียบร้อย'; st.className = 'gps-status ok';
    loc_reGeocode();
  }
  try {
    var res = await _supabase.rpc('expand_maps_url', { short_url: shortUrl });
    if(!res.error && res.data && res.data.success){ setCoords({ lat: res.data.lat, lng: res.data.lng }); return; }
    if(res.data && res.data.resolved_url){
      var c = loc_parseGoogleMapsUrl(res.data.resolved_url);
      if(c){ setCoords(c); return; }
    }
  } catch(e){ console.warn('RPC expand_maps_url failed:', e); }
  // Fallback: Edge function (TODO if needed)
  try {
    var edgeRes = await fetch(CONFIG.SUPABASE_URL + '/functions/v1/expand-url', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json', 'Authorization': 'Bearer ' + CONFIG.SUPABASE_ANON_KEY },
      body: JSON.stringify({ url: shortUrl })
    });
    var ed = await edgeRes.json();
    if(ed.success){ setCoords({ lat: ed.lat, lng: ed.lng }); return; }
    if(ed.resolvedUrl){ var c2 = loc_parseGoogleMapsUrl(ed.resolvedUrl); if(c2){ setCoords(c2); return; } }
  } catch(e){ console.warn('Edge expand failed:', e); }
  st.innerHTML = '❌ ไม่สามารถขยายลิงก์ย่อได้ — เปิดใน Google Maps แล้วคัดลอก URL แบบเต็มมาวาง';
  st.className = 'gps-status err';
}

// --- REVERSE GEOCODE (Nominatim) ---
async function loc_reverseGeocode(lat, lng){
  var result = { district:'', province:'' };
  try {
    var res = await fetch('https://nominatim.openstreetmap.org/reverse?lat='+lat+'&lon='+lng+'&format=json&accept-language=th&zoom=10');
    var data = await res.json();
    if(data && data.address){
      var a = data.address;
      result.province = (a.state || a.province || a.city || '').replace('จังหวัด','').replace('จ.','').trim();
      var distCandidates = [a.county, a.city_district, a.suburb, a.town];
      if(a.city && a.city !== result.province) distCandidates.push(a.city);
      var rawDist = distCandidates.find(function(v){ return v; }) || '';
      result.district = rawDist.replace('อำเภอ','').replace('เขต','').trim();
    }
  } catch(e){ console.warn('Reverse geocode failed:', e); }
  if(!result.district) result.district = 'ไม่ระบุอำเภอ';
  if(!result.province) result.province = 'ไม่ระบุจังหวัด';
  return result;
}

function loc_getBackfillTargets(){
  var bad = ['ไม่ระบุจังหวัด','ไม่ระบุอำเภอ','ไม่ระบุ','',null,undefined];
  return loc_customers.filter(function(c){
    if(!c.lat || !c.lng) return false;
    return bad.indexOf(c.province) !== -1 || bad.indexOf(c.district) !== -1;
  });
}
function loc_updateBackfillBadge(){
  var btn = document.getElementById('loc-backfill-btn');
  var cnt = document.getElementById('loc-backfill-count');
  if(!btn || !cnt) return;
  var targets = loc_getBackfillTargets();
  if(window._loc_isAdmin && targets.length > 0){ btn.style.display = ''; cnt.textContent = targets.length; }
  else { btn.style.display = 'none'; }
}

async function loc_backfillProvinces(){
  if(!window._loc_isAdmin) return;
  var targets = loc_getBackfillTargets();
  if(targets.length === 0){ toast('พื้นที่ของทุกเคสระบุครบแล้ว'); return; }
  var ok = await confirmDialog('อัปเดตพื้นที่จากพิกัด?',
    'จะ reverse geocode <b>'+targets.length+'</b> รายการ<br><small style="color:var(--c-muted);">~'+Math.ceil(targets.length*1.1)+' วินาที</small>',
    'อัปเดตเลย');
  if(!ok) return;
  var done = 0, fail = 0, skipped = 0;
  toast('กำลังอัปเดต ' + targets.length + ' รายการ...');
  for(var i=0;i<targets.length;i++){
    var c = targets[i];
    try {
      var geo = await loc_reverseGeocode(c.lat, c.lng);
      if(geo.province === 'ไม่ระบุจังหวัด' && geo.district === 'ไม่ระบุอำเภอ'){ skipped++; }
      else {
        var resp = await _supabase.from('loc_customers').update({ province: geo.province, district: geo.district }).eq('id', c.id);
        if(resp.error){ fail++; } else { done++; c.province = geo.province; c.district = geo.district; }
      }
    } catch(e){ fail++; }
    if(i < targets.length - 1) await new Promise(function(r){ setTimeout(r, 1100); });
  }
  toast('เสร็จ: สำเร็จ ' + done + ' · ข้าม ' + skipped + ' · ผิดพลาด ' + fail, fail === 0 ? 'success' : 'error');
  await loc_fetchData();
  loc_handleFilterChange();
}

// --- SAVE customer ---
// Photo upload via shared/cloudinary.js (loaded in <head>).
async function loc_saveCustomer(e){
  e.preventDefault();
  var g = function(id){ return (document.getElementById(id) || {}).value || ''; };
  var photoData = g('loc-form-photo-base64');
  var id = g('loc-form-id');
  if(!photoData){ toast('กรุณาอัปโหลดรูปภาพ', 'error'); return; }
  if(!g('loc-form-lat') || !g('loc-form-lng')){ toast('กรุณาระบุพิกัด', 'error'); return; }
  toast('กำลังบันทึก...');
  try {
    var photoUrl = photoData;
    if(photoData.startsWith('data:')){
      if(typeof uploadBase64ToCloudinary !== 'function'){
        throw new Error('Cloudinary script not loaded');
      }
      photoUrl = await uploadBase64ToCloudinary(photoData, 'location');
    }
    var latVal = parseFloat(g('loc-form-lat'));
    var lngVal = parseFloat(g('loc-form-lng'));
    var geoCache = g('loc-form-geo-cache');
    var geo = geoCache ? JSON.parse(geoCache) : await loc_reverseGeocode(latVal, lngVal);
    var record = {
      name: g('loc-form-name'),
      customer_type: g('loc-form-customer-type') || 'ลูกค้าทั่วไป',
      phone: g('loc-form-phone') || null,
      lat: latVal, lng: lngVal,
      district: geo.district, province: geo.province,
      details: g('loc-form-details') || null,
      photo_url: photoUrl
    };
    if(id){
      var r = await _supabase.from('loc_customers').update(record).eq('id', id);
      if(r.error) throw r.error;
      try {
        await _supabase.from('activity_log').insert({
          username: (typeof getUserName === 'function' ? getUserName() : 'Unknown'),
          role: (typeof getUserRole === 'function' ? getUserRole() : 'User'),
          action: 'LOC_UPDATE',
          target: record.name || id,
          details: 'อ.' + (record.district||'-') + ' จ.' + (record.province||'-') + ' · ' + record.lat + ',' + record.lng
        });
      } catch(_){}
    } else {
      record.id = 'CUST_' + Date.now();
      var r2 = await _supabase.from('loc_customers').insert(record);
      if(r2.error) throw r2.error;
      try {
        await _supabase.from('activity_log').insert({
          username: (typeof getUserName === 'function' ? getUserName() : 'Unknown'),
          role: (typeof getUserRole === 'function' ? getUserRole() : 'User'),
          action: 'LOC_CREATE',
          target: record.name || record.id,
          details: 'อ.' + (record.district||'-') + ' จ.' + (record.province||'-') + ' · ' + record.lat + ',' + record.lng
        });
      } catch(_){}
    }
    toast('บันทึกสำเร็จ', 'success');
    await loc_fetchData();
    loc_switchTab('customers');
  } catch(err){
    toast('ผิดพลาด: ' + (err.message || err), 'error');
  }
}

// --- CUSTOMER DETAIL MODAL ---
function loc_openModal(id){
  var c = loc_customers.find(function(x){ return x.id === id; });
  if(!c) return;
  loc_selectedCustomerId = id;
  var photo = document.getElementById('loc-modal-photo');
  if(photo){ photo.src = c.photo || 'https://via.placeholder.com/400x300'; photo.onerror = function(){ this.src = 'https://via.placeholder.com/400x300'; }; }
  document.getElementById('loc-modal-name').textContent = c.name || '';
  var typeEl = document.getElementById('loc-modal-type');
  var ct = c.customer_type || 'ลูกค้าทั่วไป';
  typeEl.textContent = ct; typeEl.className = 'ct-badge ' + (CT_CLASS[ct] || 'ct-general');
  document.getElementById('loc-modal-district').textContent = '📍 อ.' + (c.district || 'ไม่ระบุ') + ' จ.' + (c.province || 'ไม่ระบุ');
  var phoneEl = document.getElementById('loc-modal-phone');
  if(c.phone){
    phoneEl.textContent = '📞 ' + c.phone;
    phoneEl.href = 'tel:' + String(c.phone).replace(/\D/g, '');
    phoneEl.style.display = 'inline-block';
  } else { phoneEl.style.display = 'none'; }
  document.getElementById('loc-modal-details').textContent = c.details || 'ไม่มีข้อมูล';
  document.getElementById('loc-modal-coords').textContent = c.lat + ', ' + c.lng;
  document.getElementById('loc-modal-map-link').href = 'https://www.google.com/maps/search/?api=1&query=' + c.lat + ',' + c.lng;
  openModal('modal-customer');
}

function loc_editFromModal(){ closeModal('modal-customer'); loc_openFormEdit(loc_selectedCustomerId); }

// --- MINI MAP ---
var _miniMapInstance = null;
var _miniMapMarker = null;
function loc_openMiniMap(){
  var c = loc_customers.find(function(x){ return x.id === loc_selectedCustomerId; });
  if(!c || c.lat == null || c.lng == null) return;
  var lat = Number(c.lat), lng = Number(c.lng);
  document.getElementById('loc-minimap-name').textContent = c.name || 'แผนที่';
  document.getElementById('loc-minimap-coords').textContent = lat.toFixed(6) + ', ' + lng.toFixed(6);
  document.getElementById('loc-minimap-nav-link').href = 'https://www.google.com/maps/search/?api=1&query=' + lat + ',' + lng;
  openModal('modal-minimap');
  setTimeout(function(){
    if(!_miniMapInstance){
      _miniMapInstance = L.map('loc-minimap', { maxZoom: 19 }).setView([lat, lng], 16);
      // Use MapConfig so it respects Admin's map provider (Leaflet/OSM vs Google).
      if (window.MapConfig) {
        MapConfig.load(_supabase).then(function(){
          return MapConfig.createTileLayer(_miniMapInstance, { maxZoom: 19, attribution: '&copy; OpenStreetMap' });
        }).catch(function(){
          L.tileLayer('https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png', { attribution: '&copy; OpenStreetMap' }).addTo(_miniMapInstance);
        });
      } else {
        L.tileLayer('https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png', { attribution: '&copy; OpenStreetMap' }).addTo(_miniMapInstance);
      }
    } else {
      _miniMapInstance.setView([lat, lng], 16);
      _miniMapInstance.invalidateSize();
    }
    var color = CT_PIN[c.customer_type || 'ลูกค้าทั่วไป'] || '#64748b';
    var icon = L.divIcon({
      className: 'loc-marker-icon',
      html: '<svg xmlns="http://www.w3.org/2000/svg" width="36" height="46" viewBox="0 0 24 36"><path d="M12 0C5.4 0 0 5.4 0 12c0 9 12 24 12 24s12-15 12-24C24 5.4 18.6 0 12 0z" fill="'+color+'"/><circle cx="12" cy="11" r="5" fill="#fff"/></svg>',
      iconSize: [36, 46], iconAnchor: [18, 46], popupAnchor: [0, -46]
    });
    if(_miniMapMarker) _miniMapInstance.removeLayer(_miniMapMarker);
    _miniMapMarker = L.marker([lat, lng], { icon: icon }).addTo(_miniMapInstance);
    _miniMapMarker.bindPopup('<div style="font-family:Sarabun,sans-serif; min-width:160px;"><b>'+escapeHtml(c.name||'')+'</b><div style="font-size:0.78rem; color:#64748b;">อ.'+escapeHtml(c.district||'-')+' จ.'+escapeHtml(c.province||'-')+'</div></div>').openPopup();
    setTimeout(function(){ _miniMapInstance && _miniMapInstance.invalidateSize(); }, 250);
  }, 200);
}

// --- DASHBOARD + MAIN MAP ---
function loc_renderDashboard(){
  var data = loc_dashFiltered !== null ? loc_dashFiltered : loc_customers;
  document.getElementById('loc-dash-total').textContent = data.length;
  var recent = data.slice(0, 12);
  var html = '';
  recent.forEach(function(c){
    var photo = c.photo || 'https://via.placeholder.com/150?text=No+Image';
    var ct = c.customer_type || 'ลูกค้าทั่วไป';
    html += '<div class="activity-item" onclick="loc_openModal(\''+escapeHtml(c.id)+'\')">'
      + '<img src="'+escapeHtml(photo)+'" onerror="this.src=\'https://via.placeholder.com/150\'">'
      + '<div style="flex:1; min-width:0;">'
        + '<div style="font-weight:600; font-size:13px; line-height:1.3; overflow:hidden; text-overflow:ellipsis; white-space:nowrap;">'+escapeHtml(c.name||'')+'</div>'
        + '<div style="font-size:11px; color:var(--c-muted); margin-top:2px;"><span class="ct-badge '+(CT_CLASS[ct]||'ct-general')+'" style="font-size:9px;">'+escapeHtml(ct)+'</span> · อ.'+escapeHtml(c.district||'—')+'</div>'
      + '</div>'
    + '</div>';
  });
  if(!recent.length) html = '<div style="text-align:center; color:var(--c-muted); padding:30px 10px;">ยังไม่มีข้อมูล</div>';
  document.getElementById('loc-dash-recent').innerHTML = html;
  loc_initMap(data);
}

function loc_initMap(dataToRender){
  if(!dataToRender) dataToRender = loc_customers;
  var mapEl = document.getElementById('loc-map'); if(!mapEl) return;
  if(!loc_leafletMap){
    loc_leafletMap = L.map('loc-map', { maxZoom: 19 }).setView([15.7, 100.1], 6);
    // Tile layer via MapConfig: uses Google Maps if Admin enabled it, else OSM.
    if (window.MapConfig) {
      MapConfig.load(_supabase).then(function(){
        return MapConfig.createTileLayer(loc_leafletMap, { maxZoom: 19, attribution: '&copy; OpenStreetMap' });
      }).catch(function(){
        L.tileLayer('https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png', { attribution: '&copy; OpenStreetMap' }).addTo(loc_leafletMap);
      });
    } else {
      L.tileLayer('https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png', { attribution: '&copy; OpenStreetMap' }).addTo(loc_leafletMap);
    }
  } else if(loc_markersCluster){
    loc_leafletMap.removeLayer(loc_markersCluster);
  }
  loc_markersCluster = L.markerClusterGroup({ chunkedLoading: true, maxClusterRadius: 50 });
  var bounds = [];
  dataToRender.forEach(function(c){
    if(!c.lat || !c.lng) return;
    var color = CT_PIN[c.customer_type || 'ลูกค้าทั่วไป'] || '#64748b';
    var icon = L.divIcon({
      className: 'loc-marker-icon',
      html: '<svg xmlns="http://www.w3.org/2000/svg" width="28" height="36" viewBox="0 0 24 36"><path d="M12 0C5.4 0 0 5.4 0 12c0 9 12 24 12 24s12-15 12-24C24 5.4 18.6 0 12 0z" fill="'+color+'"/><circle cx="12" cy="11" r="5" fill="#fff"/></svg>',
      iconSize: [28, 36], iconAnchor: [14, 36], popupAnchor: [0, -36]
    });
    var marker = L.marker([c.lat, c.lng], { icon: icon });
    bounds.push([c.lat, c.lng]);
    var photo = c.photo || 'https://via.placeholder.com/150';
    marker.bindPopup('<div style="text-align:center; width:180px; font-family:Sarabun,sans-serif;">'
      + '<img src="'+escapeHtml(photo)+'" onerror="this.src=\'https://via.placeholder.com/150\'" style="width:100%; height:80px; object-fit:cover; border-radius:6px; margin-bottom:6px;">'
      + '<div style="font-weight:600; font-size:13px;">'+escapeHtml(c.name||'')+'</div>'
      + '<div style="font-size:11px; color:#64748b; margin-bottom:6px;">อ.'+escapeHtml(c.district||'ไม่ระบุ')+'</div>'
      + '<button onclick="loc_openModal(\''+escapeHtml(c.id)+'\')" style="background:#0ea5e9; color:#fff; border:none; padding:5px 12px; border-radius:6px; font-size:12px; cursor:pointer; width:100%; font-family:inherit;">ดูข้อมูลเต็ม</button>'
    + '</div>');
    loc_markersCluster.addLayer(marker);
  });
  loc_leafletMap.addLayer(loc_markersCluster);
  if(bounds.length === 1) loc_leafletMap.setView(bounds[0], 12);
  else if(bounds.length > 1) loc_leafletMap.fitBounds(bounds, { maxZoom: 12, padding: [40, 40] });
  else loc_leafletMap.setView([15.7, 100.1], 8);
  setTimeout(function(){ loc_leafletMap.invalidateSize(); }, 300);
}

// --- TOKENS TABLE ---
function loc_shareConfigToIcons(cfg){
  if(cfg == null) return '<span style="color:var(--c-muted); font-size:12px;">ทุกช่อง</span>';
  var icons = [
    { key:'name',    icon:'👤', label:'ชื่อ' },
    { key:'phone',   icon:'📞', label:'เบอร์' },
    { key:'coords',  icon:'📍', label:'พิกัด' },
    { key:'details', icon:'ℹ️', label:'รายละเอียด' },
    { key:'photo',   icon:'🖼️', label:'รูป' }
  ];
  return icons.map(function(it){
    var on = cfg[it.key] === true;
    return '<span title="'+it.label+(on?' (แชร์)':' (ซ่อน)')+'" style="opacity:'+(on?'1':'0.25')+'; margin-right:4px; font-size:14px;">'+it.icon+'</span>';
  }).join('');
}

function loc_renderTokensTable(){
  var tbody = document.getElementById('loc-tokens-table-body');
  var countEl = document.getElementById('loc-tokens-count');
  if(!tbody) return;
  var filterStatus = (document.getElementById('loc-tokens-filter-status') || {}).value || 'all';
  var searchQ = ((document.getElementById('loc-tokens-search') || {}).value || '').trim().toLowerCase();
  var now = Date.now();
  var filtered = (loc_sharedTokensData || []).filter(function(t){
    var exp = t.expiry_date ? new Date(t.expiry_date).getTime() : Infinity;
    var isExp = exp < now;
    var isRevoked = t.status === 'Revoked';
    var isActive = !isRevoked && !isExp;
    if(filterStatus === 'active' && !isActive) return false;
    if(filterStatus === 'revoked' && !isRevoked) return false;
    if(filterStatus === 'expired' && !(isExp && !isRevoked)) return false;
    if(searchQ){
      var cust = loc_customers.find(function(c){ return c.id === t.customer_id; });
      var hay = ((cust && cust.name) || '') + ' ' + (t.note || '') + ' ' + (t.created_by || '') + ' ' + (t.token || '');
      if(hay.toLowerCase().indexOf(searchQ) === -1) return false;
    }
    return true;
  });
  var total = (loc_sharedTokensData || []).length;
  var actives = (loc_sharedTokensData || []).filter(function(t){
    var e = t.expiry_date ? new Date(t.expiry_date).getTime() : Infinity;
    return t.status !== 'Revoked' && e >= now;
  }).length;
  if(countEl) countEl.innerHTML = 'แสดง ' + filtered.length + ' จาก ' + total + ' · ใช้งานได้ <b style="color:var(--c-success);">' + actives + '</b>';
  if(!filtered.length){
    tbody.innerHTML = '<tr><td colspan="6" style="text-align:center; color:var(--c-muted); padding:30px;">ไม่มีข้อมูลตามตัวกรอง</td></tr>';
    return;
  }
  var html = '';
  filtered.forEach(function(t){
    var exp = t.expiry_date ? new Date(t.expiry_date).getTime() : Infinity;
    var isExp = exp < now;
    var statusText = 'ใช้งานได้', statusClass = 'active';
    if(t.status === 'Revoked'){ statusText = 'ถูกระงับ'; statusClass = 'revoked'; }
    else if(isExp){ statusText = 'หมดอายุ'; statusClass = 'expired'; }
    var expText = t.expiry_date ? new Date(t.expiry_date).toLocaleString('th-TH', { dateStyle:'short', timeStyle:'short' }) : '-';
    var cust = loc_customers.find(function(c){ return c.id === t.customer_id; });
    var custName = cust ? escapeHtml(cust.name) : '<span style="color:var(--c-danger);">(ลูกค้าถูกลบ)</span>';
    var actions = '';
    if(t.status !== 'Revoked' && !isExp){
      actions += '<button class="btn-ghost" style="padding:4px 8px; font-size:11px; margin-right:4px;" onclick="loc_copyTokenLink(\''+t.token+'\')" title="คัดลอกลิงก์">📋</button>';
      actions += '<button class="btn-ghost" style="padding:4px 8px; font-size:11px; color:var(--c-danger); border-color:#fecaca;" onclick="loc_revokeToken(\''+t.token+'\')">ยกเลิก</button>';
    } else {
      actions += '<button class="btn-ghost" style="padding:4px 8px; font-size:11px;" onclick="loc_deleteToken(\''+t.token+'\')" title="ลบถาวร">🗑️</button>';
    }
    html += '<tr>'
      + '<td><div style="font-weight:600;">'+custName+'</div>'
        + '<div style="font-size:11px; color:var(--c-muted); margin-top:2px;">👤 '+escapeHtml(t.created_by||'-')
        + ' · 📅 '+(t.created_at ? new Date(t.created_at).toLocaleDateString('th-TH') : '-')
        + ' · <code style="font-size:10px;">'+escapeHtml((t.token||'').substring(0,10))+'…</code></div></td>'
      + '<td>'+loc_shareConfigToIcons(t.share_config)+'</td>'
      + '<td style="color:var(--c-muted); font-size:12px; max-width:180px; overflow:hidden; text-overflow:ellipsis; white-space:nowrap;">'+escapeHtml(t.note||'-')+'</td>'
      + '<td style="text-align:center; font-size:12px;">'+expText+'</td>'
      + '<td style="text-align:center;"><span class="status-pill '+statusClass+'">'+statusText+'</span></td>'
      + '<td style="text-align:right; white-space:nowrap;">'+actions+'</td>'
    + '</tr>';
  });
  tbody.innerHTML = html;
}

function loc_copyTokenLink(token){
  var base = window.location.origin + (typeof CONFIG !== 'undefined' && CONFIG.BASE_URL ? CONFIG.BASE_URL : '/pt-medical-system');
  var url = base + '/location/share.html?token=' + encodeURIComponent(token);
  navigator.clipboard.writeText(url).then(function(){ toast('คัดลอกลิงก์แล้ว', 'success'); }).catch(function(){ prompt('Copy this URL:', url); });
}

async function loc_deleteToken(token){
  var ok = await confirmDialog('ลบ token นี้ถาวร?', 'ข้อมูลประวัติการแชร์จะ<b>หายอย่างถาวร</b>', 'ลบถาวร', true);
  if(!ok) return;
  try {
    var res = await _supabase.from('loc_shared_tokens').delete().eq('token', token);
    if(res.error) throw res.error;
    try {
      await _supabase.from('activity_log').insert({
        username: (typeof getUserName === 'function' ? getUserName() : 'Unknown'),
        role: (typeof getUserRole === 'function' ? getUserRole() : 'User'),
        action: 'LOC_SHARE_DELETE',
        target: token.substring(0, 10) + '...',
        details: 'Permanently deleted share token'
      });
    } catch(_){}
    var d = await _supabase.from('loc_shared_tokens').select('*').order('created_at', { ascending: false });
    loc_sharedTokensData = d.data || [];
    loc_renderTokensTable();
    toast('ลบเรียบร้อย', 'success');
  } catch(err){ toast('ผิดพลาด: ' + (err.message || err), 'error'); }
}

async function loc_bulkDeleteExpired(){
  var now = Date.now();
  var targets = (loc_sharedTokensData || []).filter(function(t){
    var exp = t.expiry_date ? new Date(t.expiry_date).getTime() : Infinity;
    return t.status === 'Revoked' || exp < now;
  });
  if(!targets.length){ toast('ไม่มีข้อมูลเก่าให้ลบ'); return; }
  var ok = await confirmDialog('ลบข้อมูลเก่าทั้งหมด?', 'จะลบ <b>'+targets.length+'</b> รายการที่หมดอายุหรือถูกระงับ', 'ลบทั้งหมด', true);
  if(!ok) return;
  try {
    var tokens = targets.map(function(t){ return t.token; });
    var res = await _supabase.from('loc_shared_tokens').delete().in('token', tokens);
    if(res.error) throw res.error;
    try {
      await _supabase.from('activity_log').insert({
        username: (typeof getUserName === 'function' ? getUserName() : 'Unknown'),
        role: (typeof getUserRole === 'function' ? getUserRole() : 'User'),
        action: 'LOC_SHARE_BULK_DELETE',
        target: 'expired+revoked',
        details: 'Bulk deleted ' + tokens.length + ' tokens'
      });
    } catch(_){}
    var d = await _supabase.from('loc_shared_tokens').select('*').order('created_at', { ascending: false });
    loc_sharedTokensData = d.data || [];
    loc_renderTokensTable();
    toast('ลบ ' + tokens.length + ' รายการ', 'success');
  } catch(err){ toast('ผิดพลาด: ' + (err.message || err), 'error'); }
}

// --- SHARE LINK ---
function loc_generateToken(){
  var bytes = new Uint8Array(24);
  (window.crypto || window.msCrypto).getRandomValues(bytes);
  var b64 = btoa(String.fromCharCode.apply(null, bytes));
  return b64.replace(/\+/g, '-').replace(/\//g, '_').replace(/=/g, '').substring(0, 32);
}

function loc_shareCustomerFromRow(id){ loc_selectedCustomerId = id; loc_createShareLink(); }

function loc_createShareLink(){
  var c = loc_customers.find(function(x){ return x.id === loc_selectedCustomerId; });
  if(!c) return;
  _locShareTargetCustomerId = c.id;
  document.getElementById('locShareCustomerInfo').innerHTML =
    '<b>📍 '+escapeHtml(c.name || '-')+'</b>'
    + '<div style="color:var(--c-muted); font-size:12px; margin-top:2px;">อ.'+escapeHtml(c.district||'-')+' จ.'+escapeHtml(c.province||'-')+'</div>';
  document.getElementById('locShareExpiry').value = '24';
  document.getElementById('locShareNote').value = '';
  document.getElementById('locShareValidation').style.display = 'none';
  var wrap = document.getElementById('locShareFieldsWrap');
  wrap.innerHTML = LOC_SHARE_FIELDS.map(function(f){
    return '<label style="display:flex; align-items:center; gap:8px; padding:5px 0; cursor:pointer; font-size:13px;">'
      + '<input type="checkbox" class="loc-share-field-cb" data-field="'+f.key+'" '+(f.default?'checked':'')+'>'
      + '<span>'+f.label+'</span></label>';
  }).join('');
  closeModal('modal-customer');
  openModal('modal-share');
}

async function loc_submitShareLink(){
  var c = loc_customers.find(function(x){ return x.id === _locShareTargetCustomerId; });
  if(!c){ toast('ไม่พบข้อมูลลูกค้า', 'error'); return; }
  var expiryHours = parseInt(document.getElementById('locShareExpiry').value, 10);
  var note = (document.getElementById('locShareNote').value || '').trim();
  var shareConfig = {};
  document.querySelectorAll('.loc-share-field-cb').forEach(function(cb){ shareConfig[cb.dataset.field] = cb.checked; });
  var anyChecked = Object.keys(shareConfig).some(function(k){ return shareConfig[k]; });
  if(!anyChecked){
    var v = document.getElementById('locShareValidation');
    v.textContent = 'กรุณาเลือกข้อมูลที่จะแชร์อย่างน้อย 1 รายการ';
    v.style.display = '';
    return;
  }
  var submitBtn = document.getElementById('locShareSubmitBtn');
  var orig = submitBtn.innerHTML;
  submitBtn.disabled = true; submitBtn.innerHTML = '⏳ กำลังสร้าง...';
  var token = loc_generateToken();
  var expiryDate = new Date(Date.now() + expiryHours * 3600 * 1000);
  try {
    var baseRow = {
      token: token, customer_id: c.id, expiry_date: expiryDate.toISOString(),
      status: 'Active', note: note || null,
      created_by: (typeof getUserName === 'function' ? getUserName() : 'Unknown')
    };
    var insertRow = Object.assign({ share_config: shareConfig }, baseRow);
    var res = await _supabase.from('loc_shared_tokens').insert(insertRow).select().single();
    var schemaMissing = false;
    if(res.error){
      var em = (res.error.message || '').toLowerCase();
      if(em.indexOf('share_config') >= 0 || em.indexOf('schema cache') >= 0){
        schemaMissing = true;
        res = await _supabase.from('loc_shared_tokens').insert(baseRow).select().single();
        if(res.error) throw res.error;
      } else { throw res.error; }
    }
    var sharedLabels = LOC_SHARE_FIELDS.filter(function(f){return shareConfig[f.key];}).map(function(f){return f.label;}).join(', ');
    var hiddenLabels = LOC_SHARE_FIELDS.filter(function(f){return !shareConfig[f.key];}).map(function(f){return f.label;}).join(', ');
    try {
      await _supabase.from('activity_log').insert({
        username: (typeof getUserName === 'function' ? getUserName() : 'Unknown'),
        role: (typeof getUserRole === 'function' ? getUserRole() : 'User'),
        action: 'LOC_SHARE',
        target: c.name || c.id,
        details: 'อายุ ' + expiryHours + ' ชม. · เปิดให้เห็น: ' + (sharedLabels || '-')
                 + (hiddenLabels ? ' · ซ่อน: ' + hiddenLabels : '')
                 + (note ? ' · หมายเหตุ: ' + note : '')
                 + ' · token: ' + token.substring(0, 8) + '...'
      });
    } catch(_){}
    var base = window.location.origin + (typeof CONFIG !== 'undefined' && CONFIG.BASE_URL ? CONFIG.BASE_URL : '/pt-medical-system');
    var shareUrl = base + '/location/share.html?token=' + encodeURIComponent(token);
    closeModal('modal-share');
    document.getElementById('locShareResultUrl').value = shareUrl;
    document.getElementById('locShareResultExpire').textContent = 'หมดอายุ: ' + expiryDate.toLocaleString('th-TH');
    document.getElementById('locShareResultWarning').innerHTML = schemaMissing
      ? '<div style="background:#fef3c7; color:#854d0e; padding:8px 12px; border-radius:6px; font-size:12px; margin-top:10px;">⚠ <b>Privacy feature ยังไม่เปิด</b> — ลิงก์นี้จะโชว์ทุกช่อง · Admin: รัน <code>sql/loc_shared_tokens_add_share_config.sql</code></div>'
      : '';
    openModal('modal-share-result');
    try {
      var tRes = await _supabase.from('loc_shared_tokens').select('*').order('created_at', { ascending: false });
      loc_sharedTokensData = tRes.data || [];
      loc_updateCounts();
      if(document.getElementById('loc-tokens-view').classList.contains('active')) loc_renderTokensTable();
    } catch(_){}
  } catch(err){
    toast('ผิดพลาด: ' + (err.message || err), 'error');
  } finally {
    submitBtn.disabled = false; submitBtn.innerHTML = orig;
  }
}

function loc_copyResultLink(){
  var input = document.getElementById('locShareResultUrl');
  if(!input) return;
  input.select(); input.setSelectionRange(0, 99999);
  (navigator.clipboard ? navigator.clipboard.writeText(input.value) : Promise.reject())
    .catch(function(){ document.execCommand('copy'); })
    .finally(function(){ toast('คัดลอกเรียบร้อย', 'success'); });
}

async function loc_revokeToken(token){
  var ok = await confirmDialog('ยกเลิกลิงก์แชร์?', 'ลิงก์จะใช้ไม่ได้ทันที', 'ยกเลิกสิทธิ์', true);
  if(!ok) return;
  var res = await _supabase.from('loc_shared_tokens').update({ status: 'Revoked' }).eq('token', token);
  if(res.error){ toast('ผิดพลาด: ' + res.error.message, 'error'); return; }
  var d = await _supabase.from('loc_shared_tokens').select('*').order('created_at', { ascending: false });
  loc_sharedTokensData = d.data || [];
  loc_renderTokensTable();
  loc_updateCounts();
  toast('ยกเลิกสิทธิ์แล้ว', 'success');
}
</script>

</body>
</html>
